# ToxiClean AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Mandatory vars for OpenEnv hackathon submission ───────────────────────

# Your Hugging Face API key (mandatory — used by inference.py as API key)
HF_TOKEN=hf_your_huggingface_token_here

# Base URL for the LLM API endpoint
# HuggingFace Inference (default): https://router.huggingface.co/v1
# OpenAI:    https://api.openai.com/v1
# Together:  https://api.together.xyz/v1
# Groq:      https://api.groq.com/openai/v1
# Ollama:    http://localhost:11434/v1
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference
# Examples: Qwen/Qwen2.5-72B-Instruct, gpt-4o-mini, mistralai/Mixtral-8x7B-Instruct-v0.1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ── Optional: backward compatible alias ───────────────────────────────────
# Some providers use API_KEY instead — HF_TOKEN takes precedence
# API_KEY=your-api-key

# ── Existing project settings (keep for backward compatibility) ────────────
# Supabase (used by execution/ scripts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
