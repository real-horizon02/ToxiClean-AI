# ToxiClean AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────
# Your OpenAI (or compatible provider) API key
OPENAI_API_KEY=sk-your-key-here

# Base URL for the API. Change this to use alternative providers:
#   OpenAI:    https://api.openai.com/v1
#   Together:  https://api.together.xyz/v1
#   Groq:      https://api.groq.com/openai/v1
#   Ollama:    http://localhost:11434/v1
API_BASE_URL=https://api.openai.com/v1

# Model to use for inference
MODEL_NAME=gpt-4o-mini

# ── Existing project settings (keep for backward compatibility) ──────────
# Supabase (used by execution/ scripts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
